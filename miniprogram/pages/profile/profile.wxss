/* pages/profile/profile.wxss */
.page { padding: 0 0 120rpx; }

.profile-hero {
  background: linear-gradient(135deg, #6C63FF 0%, #8B83FF 100%);
  padding: 48rpx 32rpx 40rpx;
  display: flex; flex-direction: column; align-items: center; color: white;
}
.avatar-circle {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; font-weight: 700; margin-bottom: 16rpx;
}
.profile-name { font-size: 32rpx; font-weight: 700; margin-bottom: 10rpx; }
.pill-type { background: rgba(255,255,255,0.2); color: white; padding: 6rpx 24rpx; border-radius: 40rpx; font-size: 22rpx; }

.card { background: white; border-radius: 24rpx; padding: 28rpx 24rpx; margin: 16rpx 24rpx 0; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.section-title { font-size: 28rpx; font-weight: 600; color: #2D3748; margin-bottom: 20rpx; }
.param-hint { font-size: 22rpx; color: #A0AEC0; margin-bottom: 20rpx; }

.form-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.form-label { width: 180rpx; font-size: 26rpx; color: #4A5568; flex-shrink: 0; }
.label-sub { font-size: 20rpx; color: #A0AEC0; }
.form-input { flex: 1; font-size: 26rpx; color: #2D3748; text-align: right; }
.form-picker { flex: 1; font-size: 26rpx; color: #6C63FF; text-align: right; }
.input-placeholder { color: #A0AEC0; }

.calibrate-section { background: #F8FAFC; border-radius: 16rpx; padding: 20rpx; margin-top: 20rpx; }
.calibrate-title { font-size: 26rpx; font-weight: 600; color: #4A5568; margin-bottom: 8rpx; }
.calibrate-hint { font-size: 22rpx; color: #A0AEC0; margin-bottom: 16rpx; }
.calibrate-row { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.calib-input { flex: 1; background: white; border: 2rpx solid #E2E8F0; border-radius: 12rpx; padding: 12rpx; font-size: 22rpx; text-align: center; }
.btn-secondary { background: #F0EEFF; color: #6C63FF; border: none; border-radius: 20rpx; padding: 18rpx; font-size: 26rpx; font-weight: 600; width: 100%; }

.save-wrap { padding: 20rpx 24rpx 0; }
.btn-primary { background: #6C63FF; color: white; border: none; border-radius: 28rpx; padding: 24rpx; font-size: 28rpx; font-weight: 600; }
.save-btn { width: 100%; }

.export-hint { font-size: 22rpx; color: #A0AEC0; margin-bottom: 16rpx; }
.export-row { display: flex; align-items: center; gap: 16rpx; }
.btn-export { background: #27AE60; color: white; border: none; border-radius: 20rpx; padding: 18rpx 32rpx; font-size: 26rpx; font-weight: 600; }

.error-banner { background: #FEF0F0; color: #E53E3E; border-radius: 12rpx; padding: 16rpx 24rpx; font-size: 24rpx; margin: 16rpx 24rpx 0; }
.success-banner { background: #E6F9F0; color: #27AE60; border-radius: 12rpx; padding: 16rpx 24rpx; font-size: 24rpx; margin: 16rpx 24rpx 0; }
