/* pages/pubmed/pubmed.wxss */
.page { padding: 0 0 120rpx; }

.search-card {
  background: linear-gradient(135deg, #6C63FF 0%, #8B83FF 100%);
  padding: 32rpx 24rpx;
}
.search-title { font-size: 28rpx; font-weight: 700; color: white; margin-bottom: 20rpx; }
.search-row { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.search-input {
  flex: 1; background: white; border-radius: 16rpx;
  padding: 18rpx 20rpx; font-size: 26rpx; color: #2D3748;
}
.input-placeholder { color: #A0AEC0; }
.btn-search {
  background: #ED8936; color: white; border: none;
  border-radius: 16rpx; padding: 18rpx 28rpx; font-size: 26rpx; font-weight: 600;
}

.preset-row { display: flex; flex-wrap: wrap; gap: 10rpx; }
.preset-chip {
  background: rgba(255,255,255,0.2); color: white;
  border-radius: 40rpx; padding: 8rpx 20rpx; font-size: 22rpx;
}

.result-meta { font-size: 24rpx; color: #718096; padding: 16rpx 24rpx; }

.article-card {
  background: white; border-radius: 20rpx;
  padding: 24rpx; margin: 12rpx 24rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.article-title { font-size: 28rpx; font-weight: 600; color: #2D3748; line-height: 1.5; margin-bottom: 10rpx; }
.article-meta { display: flex; gap: 16rpx; margin-bottom: 8rpx; }
.article-journal { font-size: 22rpx; color: #6C63FF; }
.article-year { font-size: 22rpx; color: #A0AEC0; }
.article-authors { font-size: 22rpx; color: #718096; margin-bottom: 12rpx; }

.abstract-toggle { font-size: 24rpx; color: #6C63FF; margin-bottom: 8rpx; }
.abstract-text { font-size: 22rpx; color: #4A5568; line-height: 1.6; background: #F8FAFC; border-radius: 12rpx; padding: 16rpx; }

.article-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 16rpx; padding-top: 12rpx; border-top: 1rpx solid #F0F0F0; }
.pmid-text { font-size: 20rpx; color: #A0AEC0; }
.copy-btn { font-size: 22rpx; color: #6C63FF; padding: 6rpx 16rpx; background: #F0EEFF; border-radius: 20rpx; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 26rpx; color: #A0AEC0; }

.card { background: white; border-radius: 24rpx; padding: 28rpx 24rpx; margin: 16rpx 24rpx 0; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.section-title { font-size: 28rpx; font-weight: 600; color: #2D3748; margin-bottom: 16rpx; }
.history-item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.history-query { font-size: 26rpx; color: #4A5568; }
.history-count { font-size: 22rpx; color: #A0AEC0; }

.error-banner { background: #FEF0F0; color: #E53E3E; border-radius: 12rpx; padding: 16rpx 24rpx; font-size: 24rpx; margin: 16rpx 24rpx 0; }
