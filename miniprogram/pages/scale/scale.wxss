/* pages/scale/scale.wxss */
.page { padding: 0 0 120rpx; }

.scale-hero {
  background: linear-gradient(135deg, #ED8936 0%, #F6AD55 100%);
  padding: 40rpx 32rpx;
  display: flex; flex-direction: column; align-items: center;
  color: white;
}
.scale-title { font-size: 30rpx; font-weight: 700; margin-bottom: 24rpx; }

.balance-bar-wrap { width: 100%; display: flex; flex-direction: column; align-items: center; position: relative; }
.balance-beam { width: 300rpx; position: relative; display: flex; justify-content: space-between; align-items: center; }
.beam-line { position: absolute; left: 0; right: 0; top: 50%; height: 6rpx; background: rgba(255,255,255,0.8); border-radius: 3rpx; }
.pan {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 700; color: white;
  position: relative; z-index: 1;
}
.pan-val { font-size: 22rpx; font-weight: 700; }
.pan-label { font-size: 22rpx; opacity: 0.85; margin-top: 12rpx; }
.balance-bar-wrap { gap: 8rpx; }
.left-label, .right-label { font-size: 22rpx; color: rgba(255,255,255,0.85); }

.balance-status { margin-top: 16rpx; font-size: 26rpx; font-weight: 600; padding: 8rpx 24rpx; border-radius: 40rpx; background: rgba(255,255,255,0.2); }

.physics-row { display: flex; gap: 32rpx; margin-top: 16rpx; }
.physics-item { display: flex; flex-direction: column; align-items: center; }
.physics-label { font-size: 20rpx; opacity: 0.8; }
.physics-val { font-size: 26rpx; font-weight: 700; }

.card { background: white; border-radius: 24rpx; padding: 28rpx 24rpx; margin: 16rpx 24rpx 0; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.section-title { font-size: 28rpx; font-weight: 600; color: #2D3748; margin-bottom: 20rpx; }

.food-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 20rpx; }
.food-chip-wrap { display: flex; align-items: center; }
.food-chip { background: #F8FAFC; border: 2rpx solid #E2E8F0; border-radius: 40rpx; padding: 12rpx 20rpx; font-size: 26rpx; color: #4A5568; display: flex; align-items: center; gap: 8rpx; }
.food-chip-wrap .chip-counter-btn + .food-chip { border-radius: 40rpx; }
.chip-counter-btn { background: #6C63FF; color: white; font-size: 26rpx; font-weight: 700; padding: 10rpx 12rpx; border-radius: 20rpx; margin-left: 6rpx; line-height: 1; }
.food-selected { background: #FFF3E0; border-color: #ED8936; color: #C05621; }
.chip-qty { background: #ED8936; color: white; border-radius: 20rpx; padding: 2rpx 10rpx; font-size: 20rpx; }

.search-row { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.search-input { flex: 1; background: #F8FAFC; border: 2rpx solid #E2E8F0; border-radius: 16rpx; padding: 16rpx 20rpx; font-size: 26rpx; }
.btn-add { background: #ED8936; color: white; border: none; border-radius: 16rpx; padding: 16rpx 24rpx; font-size: 26rpx; font-weight: 600; }
.input-placeholder { color: #A0AEC0; }

.risk-list { border-top: 1rpx solid #F0F0F0; padding-top: 16rpx; }
.risk-item { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 0; }
.risk-name { font-size: 26rpx; color: #2D3748; }
.risk-right { display: flex; align-items: center; gap: 12rpx; }
.risk-score { font-size: 28rpx; font-weight: 700; color: #ED8936; }
.pill { padding: 4rpx 16rpx; border-radius: 40rpx; font-size: 22rpx; }
.pill-low    { background: #E6F9F0; color: #27AE60; }
.pill-medium { background: #FFF8E1; color: #E67E22; }
.pill-high   { background: #FEF0F0; color: #E53E3E; }
.pill-very_high { background: #FEF0F0; color: #E53E3E; }

.solution-list { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 20rpx; }
.solution-item { display: flex; align-items: center; gap: 16rpx; border: 2rpx solid #E2E8F0; border-radius: 16rpx; padding: 16rpx; }
.solution-selected { border-color: #ED8936; background: #FFF3E0; }
.solution-icon { font-size: 36rpx; }
.solution-body { flex: 1; }
.solution-name { font-size: 26rpx; font-weight: 600; color: #2D3748; }
.solution-desc { font-size: 22rpx; color: #718096; margin-top: 4rpx; }
.solution-weight { font-size: 28rpx; font-weight: 700; color: #27AE60; }

.add-exercise-row { display: flex; gap: 12rpx; }
.exercise-input { flex: 2; background: #F8FAFC; border: 2rpx solid #E2E8F0; border-radius: 16rpx; padding: 14rpx 16rpx; font-size: 24rpx; }
.duration-input { flex: 1; background: #F8FAFC; border: 2rpx solid #E2E8F0; border-radius: 16rpx; padding: 14rpx 16rpx; font-size: 24rpx; }

.advice-card { background: #FFFBF5; }
.advice-text { font-size: 26rpx; color: #4A5568; line-height: 1.7; }

.loading-wrap { text-align: center; padding: 40rpx; color: #999; font-size: 26rpx; }
.error-banner { background: #FEF0F0; color: #E53E3E; border-radius: 12rpx; padding: 16rpx 24rpx; font-size: 24rpx; margin: 16rpx 24rpx 0; }
